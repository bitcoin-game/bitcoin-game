{
  "name": "bitcoin-game",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:miniapp": "npm run dev --workspace=apps/miniapp",
    "build": "npm run build --workspace=apps/miniapp && npm run prisma:generate",
    "start": "npm run start:prod --workspace=apps/api",
    "prisma:generate": "npm run prisma:generate --workspace=apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:reset-dev": "npm run db:reset-dev --workspace=apps/api"
  }
}
