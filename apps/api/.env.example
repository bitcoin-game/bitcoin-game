# URL de conexão do Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/bitcoin_game?schema=public"

# Token do bot, gerado pelo @BotFather (NUNCA expor no frontend)
BOT_TOKEN="123456:ABC-DEF..."

# Segredo p/ assinar os JWTs de sessão
JWT_SECRET="troque-por-um-segredo-forte"

# Duração do JWT de sessão
JWT_EXPIRES_IN="1h"

# Porta da API
PORT=3000

# Em dev, permite pular a validação do HMAC do initData (NUNCA em produção)
ALLOW_DEV_AUTH=false
